# ═══════════════════════════════════════════════════════════════════════════════
# Gigva Kenya — .env.local
# Rename this file to .env.local before running the dev server.
# NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex

# ── Superuser / Admin ─────────────────────────────────────────────────────────
# Creates the system superadmin on first startup (if not already in DB).
ADMIN_EMAIL=infoeddie1@gmail.com
ADMIN_PASSWORD=@G19631993

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/gigva.sqlite

# ── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Webmail URL (shown to staff in their dashboard inbox button) ──────────────
# Google Workspace: https://mail.google.com
# Zoho Mail:        https://mail.zoho.com
NEXT_PUBLIC_WEBMAIL_URL=https://mail.google.com

# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL (SMTP)
# ─────────────────────────────────────────────────────────────────────────────
# OPTION A — Google Workspace (preferred)
# ─────────────────────────────────────────────────────────────────────────────
# 1. In Google Admin Console, create noreply@gigva.co.ke
# 2. Enable 2-Step Verification on that account
# 3. Go to myaccount.google.com → Security → App passwords
# 4. Generate an app password (select "Mail" + "Other")
# 5. Paste the 16-character app password as SMTP_PASS below
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@gigva.co.ke
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM="Gigva Kenya" <noreply@gigva.co.ke>
#
# ─────────────────────────────────────────────────────────────────────────────
# OPTION B — Zoho Mail
# ─────────────────────────────────────────────────────────────────────────────
# 1. In Zoho Mail Admin, create noreply@gigva.co.ke
# 2. Go to Settings → Security → App Passwords → Generate
#
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@gigva.co.ke
# SMTP_PASS=your-zoho-app-password
# SMTP_FROM="Gigva Kenya" <noreply@gigva.co.ke>
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Email notification routing (optional overrides) ───────────────────────────
# Comma-separated @gigva.co.ke addresses to notify for each event.
# Defaults are defined in lib/roleConfig.js — only set these to override.
#
# NOTIFY_CONTACT_TO=ceo@gigva.co.ke,samuel.otieno@gigva.co.ke
# NOTIFY_DEMO_TO=ceo@gigva.co.ke,samuel.otieno@gigva.co.ke,njeri.mwangi@gigva.co.ke
# NOTIFY_TRIAL_TO=ceo@gigva.co.ke,cto@gigva.co.ke,samuel.otieno@gigva.co.ke,edward.gitau@gigva.co.ke

NODE_ENV=development

# ── Live Chat (Tawk.to) ───────────────────────────────────────────────────────
# 1. Create a free account at https://www.tawk.to
# 2. Add a Property → name it "Gigva Kenya"
# 3. Copy the IDs from Dashboard → Administration → Channels → Chat Widget
#    Direct Chat Link format: https://tawk.to/chat/{PROPERTY_ID}/{WIDGET_ID}
# 4. In Tawk.to dashboard set:
#      Color:         #0ea5e9
#      Inbox email:   samuel.otieno@gigva.co.ke
#      Offline email: samuel.otieno@gigva.co.ke
#      Welcome msg:   "Hi, we're here to help you get set up with Gigva."
#      Offline msg:   "Leave your details and we'll get back to you shortly."
NEXT_PUBLIC_TAWK_PROPERTY_ID=your_property_id_here
NEXT_PUBLIC_TAWK_WIDGET_ID=default
